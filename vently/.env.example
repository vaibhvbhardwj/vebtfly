# Vently Environment Configuration
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control!

# Database Configuration (already in application.properties)
# spring.datasource.url=jdbc:postgresql://localhost:5432/vently
# spring.datasource.username=postgres
# spring.datasource.password=your-password

# AWS S3 Configuration (Required for file uploads)
AWS_ACCESS_KEY=your-aws-access-key-id
AWS_SECRET_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=vently-profile-pictures

# Razorpay Configuration (Required for payments - India)
# Get these from: https://dashboard.razorpay.com/app/keys
# For Test Mode: Use test keys (they start with rzp_test_)
# For Live Mode: Use live keys (they start with rzp_live_)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# Stripe Configuration (Optional - only if using Stripe instead of Razorpay)
# STRIPE_API_KEY=sk_test_your-stripe-secret-key

# AWS SES Configuration (Optional - for email notifications)
# AWS_SES_REGION=us-east-1
# AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# JWT Configuration (Optional - defaults are fine for development)
# JWT_SECRET=your-custom-jwt-secret-key-here
# JWT_EXPIRATION=86400000

# Application Configuration
# SERVER_PORT=8080
